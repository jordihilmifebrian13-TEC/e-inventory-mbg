# Contoh variabel lingkungan — salin ke `.env` dan sesuaikan.
# Jangan commit file `.env` ke Git.

# PostgreSQL (Prisma)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mbg_inventory?schema=public"

# Auth.js / NextAuth v5
AUTH_SECRET="ganti-dengan-string-panjang-acak-min-32-karakter"
AUTH_URL="http://localhost:3000"

# URL publik aplikasi (metadata, link absolut)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cloudflare Turnstile (wajib di produksi)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Hanya pengembangan lokal: bypass verifikasi Turnstile di server
DEV_BYPASS_TURNSTILE="false"
